    "directory": "cli"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "author": "Ennio Maldonado",
  "dependencies": {
    "commander": "^14",
    "@praefectus/shared": "*"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "vitest": "^3"
  }
